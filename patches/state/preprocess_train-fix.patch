+def _sample_values(X, n=100000):
+    """Randomly sample a subset of values from the matrix (supports sparse matrices)."""
+    if sparse.issparse(X):
+        values = X.data
+    else:
+        values = np.asarray(X).ravel()
+
+    if values.size == 0:
+        return values
+
+    if values.size > n:
+        rng = np.random.default_rng(0)
+        idx = rng.choice(values.size, size=n, replace=False)
+        values = values[idx]
+
+    return values
+
+
+def is_already_log1p(adata) -> bool:
+    """Check whether the AnnData object has likely already been log1p-transformed."""
+    # 1. Scanpy may record log1p information in adata.uns
+    if "log1p" in adata.uns:
+        return True
+
+    values = _sample_values(adata.X)
+    if values.size == 0:
+        return False
+
+    # 2. Negative values indicate the matrix has already been transformed
+    if np.nanmin(values) < 0:
+        return True
+
+    positive = values[values > 0]
+    if positive.size == 0:
+        return False
+
+    # 3. A large fraction of non-integer values suggests the data
+    # is not raw counts and has likely already been log1p-transformed
+    frac_part = np.abs(positive - np.round(positive))
+    non_integer_ratio = np.mean(frac_part > 1e-6)
+
+    return non_integer_ratio > 0.1
+
