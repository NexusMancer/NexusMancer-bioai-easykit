# ================== General ignores ==================
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
.venv/
ENV/
*.py[cod]

# Jupyter notebook cache
.ipynb_checkpoints/
*.ipynb_checkpoints

# macOS / Windows temporary files
.DS_Store
Thumbs.db

# Build / packaging files (for future PyPI package)
build/
dist/
*.egg-info/
*.egg

# Large data files (we use cloud storage instead)
/dataset/*
!/dataset/.gitkeep
*h5ad
*h5
*h5py
*h5py.File
*h5py.Group
*h5py.Dataset
*h5py.Attribute
*h5py.ExternalLink
*h5py.SoftLink

# ================== Project-specific ignores ==================
# Tool repositories that are cloned automatically by install.sh
# We ignore everything inside tools/, but keep the empty folder via .gitkeep
/tools/*
!/tools/.gitkeep

# Temporary patch backup files
*.patch.bak

# Logs and temporary outputs
/logs/*
!/logs/.gitkeep
/results/*
!/results/.gitkeep
outputs/
tmp/
temp/

# Conda environment lock file (do not upload local environment)
environment.yml.lock

# ====================== Weights & Biases (wandb) ======================
wandb/
.wandb/
wandb.log
*.wandb
wandb-metadata.json
wandb-debug.log
wandb-summary.json

tea_debug.log